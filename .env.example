# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Put values directly after '='. Keep comments on their OWN lines (an inline
# comment after an EMPTY value is parsed as the value by python-dotenv).

# --- AI / image providers ---------------------------------------------------
# Google AI Studio key(s). Multiple keys are rotated round-robin to spread load
# and dodge rate limits. Add as many as you have (GEMINI_API_KEY, _2, _3, _4, _5).
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
# Pexels image API key (https://www.pexels.com/api)
PEXELS_API_KEY=

# --- Gemini model + retry tuning (pinned stable model, NOT *-latest) ---------
GEMINI_MODEL=gemini-2.5-flash
# Fallback model, used after 2 consecutive 503s on the primary. Either name works.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite
GEMINI_MIN_SECONDS_BETWEEN_CALLS=30
GEMINI_MAX_RETRIES=5
GEMINI_RETRY_BASE_SECONDS=30
GEMINI_RETRY_MAX_SECONDS=300
GEMINI_RETRY_JITTER=true
GEMINI_COOLDOWN_AFTER_429_SECONDS=90
GEMINI_COOLDOWN_AFTER_503_SECONDS=180

# --- Staggered publishing (minutes between sites; 3 for ~10 sites, 4 for ~15) -
STAGGER_GAP_MIN=3

# --- WordPress application passwords ----------------------------------------
# One env var per site, named by `app_password_env` in config/sites.yaml.
# Generate under Users -> Profile -> Application Passwords in each WP admin.
WP_PASS_SITE1=
WP_PASS_SITE2=
WP_PASS_SITE3=
WP_PASS_SITE4=
WP_PASS_SITE5=
WP_PASS_SITE6=
WP_PASS_SITE7=
WP_PASS_SITE8=
WP_PASS_SITE9=
WP_PASS_SITE10=

# --- Email digest (sent after each full run) --------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
ADMIN_MAIL=

# --- Telegram digest (optional alternative to email) ------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
